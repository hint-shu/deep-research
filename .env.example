# =====================================================================
# Deep Research — environment template
# Copy this file to .env and fill in your own keys. DO NOT commit .env.
# Most keys actually go into ~/.claude.json (MCP configs), not here.
# This file is documentation of what you need and where.
# =====================================================================

# ─── REQUIRED for all tiers ─────────────────────────────────────────────

# Firecrawl — scraping engine (L0-L5)
# Sign up: https://www.firecrawl.dev (free: 500 scrapes one-time)
# Used by: Firecrawl CLI — reads from env OR `firecrawl config` OAuth
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── REQUIRED for L1-L5 ────────────────────────────────────────────────

# Tavily — keyword search API (L1-L5 discovery channel)
# Sign up: https://tavily.com (free: 1000 searches/month recurring)
# Goes into: ~/.claude.json as tavily MCP server URL
# ?tavilyApiKey=<this_key> in the URL
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — neural search (v0.5.0+) ────────────────────────────────

# Exa — neural semantic search (L2-L5)
# Sign up: https://exa.ai (free: 1000 searches/month)
# Install: claude mcp add --transport http exa 'https://mcp.exa.ai/mcp?exaApiKey=<KEY>&tools=...'
# See: docs/EXA_INTEGRATION.md
EXA_API_KEY=exa-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — answer engine (v0.6.0+) ────────────────────────────────

# Perplexity — synthesized answers with citations (L0-L5)
# Sign up: https://perplexity.ai/settings/api
# Install: claude mcp add perplexity-ask -e "PERPLEXITY_API_KEY=<KEY>" -- npx -y server-perplexity-ask
# See: docs/PERPLEXITY_INTEGRATION.md
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL — cross-model channel (v0.2.0+) ──────────────────────────

# OpenAI Codex CLI — GPT-5.4 with agentic web search
# Install: brew install openai/tap/codex
# Auth: codex auth login (no env var — stores locally)
# Requires ChatGPT Pro subscription ($200/month) for GPT-5.4.
# See: docs/CODEX_INTEGRATION.md

# ─── OPTIONAL — disable flags (force single-channel mode) ──────────────

# DEEP_RESEARCH_DISABLE_CODEX=1        # skip Codex cross-model calls
# DEEP_RESEARCH_DISABLE_EXA=1          # skip Exa neural search
# DEEP_RESEARCH_DISABLE_PERPLEXITY=1   # skip Perplexity answer engine
